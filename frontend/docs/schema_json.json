{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "LoginRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "minLength": 1,
          "format": "email"
        },
        "password": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "email",
        "password"
      ],
      "additionalProperties": false
    },
    "JwtAuthResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        },
        "token": {
          "type": "string"
        },
        "user_id": {
          "type": "integer"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      },
      "required": [
        "message",
        "token",
        "user_id",
        "email"
      ],
      "additionalProperties": false
    },
    "RegisterRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "minLength": 1,
          "format": "email"
        },
        "password": {
          "type": "string",
          "minLength": 6
        },
        "confirm_password": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "email",
        "password",
        "confirm_password"
      ],
      "additionalProperties": false
    },
    "AuthStatus": {
      "type": "object",
      "properties": {
        "is_authenticated": {
          "type": "boolean"
        },
        "user_name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "is_authenticated",
        "user_name"
      ],
      "additionalProperties": false
    },
    "Photo": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "title": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 255
            },
            {
              "type": "null"
            }
          ]
        },
        "url": {
          "type": "string",
          "maxLength": 1000
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "route_id": {
          "type": "integer"
        }
      },
      "required": [
        "id",
        "url",
        "route_id"
      ],
      "additionalProperties": false
