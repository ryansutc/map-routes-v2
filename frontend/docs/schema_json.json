          "type": "string",
          "format": "date-time"
        },
        "activity_type": {
          "type": "string",
          "maxLength": 100
        },
        "distance": {
          "type": "string",
          "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "route_link": {
