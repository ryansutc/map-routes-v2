{
    "openapi": "3.0.3",
    "info": {
        "title": "Map Routes API",
        "version": "1.0.0"
    },
    "paths": {
        "/api/auth/google/": {
            "get": {
                "operationId": "auth_google_retrieve",
                "tags": [
                    "auth"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "302": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "description": "Redirect to Google OAuth login"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/auth/login-jwt/": {
            "post": {
                "operationId": "auth_login_jwt_create",
                "tags": [
                    "auth"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JwtAuthResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/auth/logout/": {
            "post": {
                "operationId": "auth_logout_create",
                "tags": [
                    "auth"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "description": "Logout successful"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/auth/register-jwt/": {
            "post": {
                "operationId": "auth_register_jwt_create",
                "tags": [
                    "auth"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterRequest"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JwtAuthResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/auth/status/": {
            "get": {
                "operationId": "auth_status_retrieve",
                "tags": [
                    "auth"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthStatus"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/route/": {
            "get": {
                "operationId": "route_list",
                "tags": [
                    "route"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Route"
                                    }
                                }
                            }
                        },
                        "description": ""
                    }
                }
            },
            "post": {
                "operationId": "route_create",
                "tags": [
                    "route"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RouteWriteRequest"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/RouteWriteRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RouteWriteRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "jwtAuth": []
                    }
                ],
                "responses": {
                    "201": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RouteWrite"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/route/{id}/": {
            "get": {
                "operationId": "route_retrieve",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "schema": {
                            "type": "integer"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "route"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Route"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            },
            "put": {
                "operationId": "route_update",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "schema": {
                            "type": "integer"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "route"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RouteWriteRequest"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/RouteWriteRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RouteWriteRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "jwtAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RouteWrite"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            },
            "patch": {
                "operationId": "route_partial_update",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "schema": {
                            "type": "integer"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "route"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/PatchedRouteWriteRequest"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/PatchedRouteWriteRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/PatchedRouteWriteRequest"
                            }
                        }
                    }
                },
                "security": [
                    {
                        "jwtAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RouteWrite"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            },
            "delete": {
                "operationId": "route_destroy",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "schema": {
                            "type": "integer"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "route"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No response body"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "AuthStatus": {
                "type": "object",
                "properties": {
                    "is_authenticated": {
                        "type": "boolean"
                    },
                    "user_name": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "required": [
                    "is_authenticated",
                    "user_name"
                ]
            },
            "JwtAuthResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "token": {
                        "type": "string"
                    },
                    "user_id": {
                        "type": "integer"
                    },
                    "email": {
                        "type": "string",
                        "format": "email"
                    }
                },
                "required": [
                    "email",
                    "message",
                    "token",
                    "user_id"
                ]
            },
            "LoginRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "minLength": 1
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true,
                        "minLength": 1
                    }
                },
                "required": [
                    "email",
                    "password"
                ]
            },
            "PatchedRouteWriteRequest": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 255
                    },
                    "activity_date": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "activity_type": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100
                    },
                    "distance": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$"
                    },
                    "notes": {
                        "type": "string",
                        "nullable": true
                    },
                    "route_link": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "is_public": {
                        "type": "boolean"
                    }
                }
            },
            "Photo": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "title": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 255
                    },
                    "url": {
                        "type": "string",
                        "maxLength": 1000
                    },
                    "latitude": {
                        "type": "number",
                        "format": "double"
                    },
                    "longitude": {
                        "type": "number",
                        "format": "double"
                    },
                    "route_id": {
                        "type": "integer",
                        "readOnly": true
                    }
                },
                "required": [
                    "id",
                    "route_id",
                    "url"
                ]
            },
            "RegisterRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "minLength": 1
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true,
                        "minLength": 6
                    },
                    "confirm_password": {
                        "type": "string",
                        "writeOnly": true,
                        "minLength": 1
                    }
                },
                "required": [
                    "confirm_password",
                    "email",
                    "password"
                ]
            },
            "Route": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "title": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 255
                    },
                    "activity_date": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "activity_type": {
                        "type": "string",
                        "maxLength": 100
                    },
                    "distance": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$"
                    },
                    "notes": {
                        "type": "string",
                        "nullable": true
                    },
                    "route_link": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "owner": {
                        "type": "string",
                        "format": "email",
                        "readOnly": true
                    },
                    "is_public": {
                        "type": "boolean"
                    },
                    "photos": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Photo"
                        },
                        "readOnly": true
                    }
                },
                "required": [
                    "activity_date",
                    "activity_type",
                    "id",
                    "owner",
                    "photos"
                ]
            },
            "RouteWrite": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "title": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 255
                    },
                    "activity_date": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "activity_type": {
                        "type": "string",
                        "maxLength": 100
                    },
                    "distance": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$"
                    },
                    "notes": {
                        "type": "string",
                        "nullable": true
                    },
                    "route_link": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "is_public": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "activity_date",
                    "activity_type",
                    "id"
                ]
            },
            "RouteWriteRequest": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 255
                    },
                    "activity_date": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "activity_type": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100
                    },
                    "distance": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$"
                    },
                    "notes": {
                        "type": "string",
                        "nullable": true
                    },
                    "route_link": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "is_public": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "activity_date",
                    "activity_type"
                ]
            }
        },
        "securitySchemes": {
            "jwtAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}