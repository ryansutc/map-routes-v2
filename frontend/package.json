{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' pnpm exec tsc -b && NODE_OPTIONS='--max-old-space-size=8192' pnpm exec vite build && pnpm run copy-esri-assets",
    "copy-esri-assets": "cp -r node_modules/@arcgis/core/assets ../Backend/wwwroot/react/assets/esri",
    "lint": "eslint .",
    "preview": "vite preview",
    "schema-fetch": "curl -s 'http://localhost:8000/api/schema/?format=json' -o ./docs/schema.json",
    "schema-to-zod": "openapi-zod-client ./docs/schema.json --output ./src/generatedtypes/django_generated.ts --with-docs --with-description  -p ./.prettierrc && ./cleanup_django_generated.sh",
    "schema-zod-to-json": "tsx generate-schema-types.ts",
    "schema-json-to-ts": "json2ts -i ./docs/schema.json -o ./src/types/django_api_types.ts",
    "schema": "pnpm run schema-fetch && pnpm run schema-to-zod",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@arcgis/core": "^4.33.11",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.2.0",
    "@redux-devtools/extension": "^3.3.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.130.2",
    "@tanstack/react-router-devtools": "^1.130.2",
    "@zodios/core": "^10.9.6",
    "axios": "^1.10.0",
    "json-schema-to-typescript": "^15.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tanstack/eslint-plugin-router": "^1.129.7",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@tanstack/router-plugin": "^1.130.2",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-dom": "^1.52.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "openapi-zod-client": "^1.18.3",
    "terser": "^5.43.1",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-tsconfig-paths": "^5.1.4",
    "zod-to-json-schema": "^3.24.6"
  }
}
